# =============================================================================
# InsightOCR Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# For development: Use .env.dev.example as reference
# For production: Use .env.prod.example as reference
# =============================================================================

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# SECRET_KEY: Used for JWT token signing. Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL: PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Development: Use 'db' as host (Docker service name)
# Production: Use actual database host
DATABASE_URL=postgresql://postgres:postgres@db:5432/softnix_ocr

# -----------------------------------------------------------------------------
# Redis (Message Broker for Celery)
# -----------------------------------------------------------------------------
# REDIS_URL: Redis connection string for task queue
# Development: Use 'redis' as host (Docker service name)
# Production: Use actual Redis host
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# BACKEND_CORS_ORIGINS: Comma-separated list of allowed origins
# Development: localhost origins
# Production: Your actual frontend domain(s)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# BACKEND_EXTRA_CORS_ORIGINS: Additional CORS origins (optional)
# Use this for additional domains without overwriting defaults
BACKEND_EXTRA_CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# STORAGE_TYPE: Where to store uploaded files
# Options: local, minio, s3
STORAGE_TYPE=local

# MinIO Configuration (Required if STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=insightocr
MINIO_SECURE=False

# AWS S3 Configuration (Required if STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your-bucket-name

# -----------------------------------------------------------------------------
# OCR Service Configuration
# -----------------------------------------------------------------------------
# OCR_ENDPOINT: External OCR service endpoint for document processing
# This is used as the default value when no setting exists in database
# Can be overridden via UI Settings page
OCR_ENDPOINT=https://your-ocr-service.com:9001/ai-process-file

# TEST_ENDPOINT: External OCR service test/health check endpoint
# Used to verify OCR service connectivity
TEST_ENDPOINT=https://your-ocr-service.com:9001/me

# -----------------------------------------------------------------------------
# AI Provider Configuration (Optional)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY: OpenAI API key for additional AI features
# Leave empty if not using OpenAI
OPENAI_API_KEY=

# AI_PROVIDER_URL: Custom AI provider endpoint (optional)
# AI_PROVIDER_URL=https://your-ai-provider.com/api/completion-messages

# AI_PROVIDER_KEY: Custom AI provider API key (optional)
# AI_PROVIDER_KEY=your-ai-provider-api-key
