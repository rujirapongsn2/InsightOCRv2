# =============================================================================
# InsightOCRv2 — Backend Environment
# =============================================================================
# Used by the FastAPI backend + Celery worker containers.
# Root compose credentials live in ../.env (see ../.env.example).
#
# Quick start:
#   ./scripts/setup.sh          # prompts for OCR endpoint, copies this file
# Or manual:
#   cp backend/.env.example backend/.env
#   # fill in OCR_ENDPOINT + API_TOKEN below
# =============================================================================

# ── REQUIRED: OCR service (system non-functional without this) ──────────────
# External OCR service endpoint for document processing.
# Example: https://ocr.example.com:9001/ai-process-file
OCR_ENDPOINT=

# Health-check endpoint for the OCR service (optional but recommended).
TEST_ENDPOINT=

# API token for the OCR service (Bearer auth).
API_TOKEN=

# Optional OCR fallback provider key. Keep this value in backend/.env only.
MISTRAL_API_KEY=
OCR_SSE_IDLE_TIMEOUT_SECONDS=180

# ── Security ────────────────────────────────────────────────────────────────
# SECRET_KEY is loaded from ../.env (root) — generated by setup.sh.
# Override here only if you need a backend-specific key.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ────────────────────────────────────────────────────────────────
# Hostname `db` matches the docker-compose service name.
DATABASE_URL=postgresql://insightocr_user:${DB_PASSWORD}@db:5432/softnix_ocr

# ── Redis (Celery broker + progress cache) ──────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── CORS ────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
BACKEND_EXTRA_CORS_ORIGINS=

# ── Storage ─────────────────────────────────────────────────────────────────
# STORAGE_TYPE: local | minio | s3
# - local: files saved to docker volume (simplest)
# - minio: S3-compatible, MinIO runs in compose
# - s3: AWS S3 (set AWS_* below)
STORAGE_TYPE=local

# MinIO (used when STORAGE_TYPE=minio)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=insightocr
MINIO_SECURE=False

# AWS S3 (used when STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=

# ── AI Provider (optional — enables Simple Mode schema suggestions) ─────────
# OPENAI_API_KEY=
# AI_PROVIDER_URL=https://your-ai-provider.com/api/completion-messages
# AI_PROVIDER_KEY=
