# =============================================================================
# InsightDOC Backend - PRODUCTION Environment
# =============================================================================
# Copy this file to .env for production deployment
# IMPORTANT: Update ALL values before deploying to production
# =============================================================================

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
# CRITICAL: Generate a strong secret key for production
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE-THIS-TO-A-STRONG-RANDOM-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Database (Production)
# -----------------------------------------------------------------------------
# Use your production database host (NOT 'db' service name)
# Examples:
# - Managed database: your-db.region.rds.amazonaws.com
# - Internal host: 10.0.1.5
# - Cloud database: your-project.supabase.co
DATABASE_URL=postgresql://username:password@your-db-host:5432/softnix_ocr

# -----------------------------------------------------------------------------
# Redis (Production)
# -----------------------------------------------------------------------------
# Use your production Redis host (NOT 'redis' service name)
# Examples:
# - Managed Redis: your-redis.cache.amazonaws.com
# - Internal host: 10.0.1.6
REDIS_URL=redis://your-redis-host:6379/0

# -----------------------------------------------------------------------------
# CORS Configuration (Production)
# -----------------------------------------------------------------------------
# IMPORTANT: Set to your actual production frontend domain(s)
# Format: protocol://domain:port (comma-separated for multiple)
BACKEND_CORS_ORIGINS=http://env-1805534.th2.proen.cloud:3000
BACKEND_EXTRA_CORS_ORIGINS=

# If using HTTPS (recommended for production):
# BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# -----------------------------------------------------------------------------
# Storage Configuration (Production)
# -----------------------------------------------------------------------------
# Recommended: Use object storage (minio or s3) for production
STORAGE_TYPE=minio

# MinIO Configuration (Production)
MINIO_ENDPOINT=your-minio-host:9000
MINIO_ACCESS_KEY=your-production-access-key
MINIO_SECRET_KEY=your-production-secret-key
MINIO_BUCKET=insightocr-prod
MINIO_SECURE=True

# AWS S3 Configuration (Alternative to MinIO)
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=ap-southeast-1
# AWS_BUCKET_NAME=insightocr-prod

# -----------------------------------------------------------------------------
# OCR Service Configuration (Production)
# -----------------------------------------------------------------------------
# IMPORTANT: Set to your production OCR service endpoint
OCR_ENDPOINT=https://your-production-ocr-service.com:9001/ai-process-file
TEST_ENDPOINT=https://your-production-ocr-service.com:9001/me

# Alternative examples:
# Internal service: http://10.0.2.10:9001/ai-process-file
# Cloud service: https://ocr-api.yourcompany.com/ai-process-file

# -----------------------------------------------------------------------------
# AI Provider Configuration (Production)
# -----------------------------------------------------------------------------
# Set if using OpenAI or custom AI provider
OPENAI_API_KEY=

# Production AI Provider
# AI_PROVIDER_URL=https://genai.softnix.ai/external/api/completion-messages
# AI_PROVIDER_KEY=your-production-api-key
