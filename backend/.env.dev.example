# =============================================================================
# InsightDOC Backend - DEVELOPMENT Environment
# =============================================================================
# Copy this file to .env for local development
# =============================================================================

# -----------------------------------------------------------------------------
# Security (Development)
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-change-this-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Database (Development - Docker Compose)
# -----------------------------------------------------------------------------
# Use Docker service name 'db' as host
DATABASE_URL=postgresql://postgres:postgres@db:5432/softnix_ocr

# -----------------------------------------------------------------------------
# Redis (Development - Docker Compose)
# -----------------------------------------------------------------------------
# Use Docker service name 'redis' as host
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# CORS Configuration (Development)
# -----------------------------------------------------------------------------
# Allow localhost origins for local development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
BACKEND_EXTRA_CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Storage Configuration (Development)
# -----------------------------------------------------------------------------
# Use local storage for development
STORAGE_TYPE=local

# MinIO (Optional - if you want to test MinIO locally)
# STORAGE_TYPE=minio
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=insightocr
# MINIO_SECURE=False

# -----------------------------------------------------------------------------
# OCR Service Configuration (Development)
# -----------------------------------------------------------------------------
# Point to your development OCR service
# Replace with your actual development OCR endpoint
OCR_ENDPOINT=https://111.223.37.41:9001/ai-process-file
TEST_ENDPOINT=https://111.223.37.41:9001/me

# Alternative: Use localhost if running OCR service locally
# OCR_ENDPOINT=http://localhost:9001/ai-process-file
# TEST_ENDPOINT=http://localhost:9001/me

# -----------------------------------------------------------------------------
# AI Provider Configuration (Development)
# -----------------------------------------------------------------------------
# Leave empty if not needed for development
OPENAI_API_KEY=

# Development AI Provider (if using custom provider)
# AI_PROVIDER_URL=https://genai.softnix.ai/external/api/completion-messages
# AI_PROVIDER_KEY=your-dev-api-key
