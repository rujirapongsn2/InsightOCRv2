
# Ignore uploads
backend/uploads/
!backend/uploads/.gitkeep
# Environment files with actual credentials (DO NOT COMMIT)
backend/.env
backend/.env.local
frontend/.env.local
.env

# Allow example env files to be committed
!backend/.env.example
!backend/.env*.example
!frontend/.env.example
!frontend/.env*.example
/.git_old/
frontend/.next
frontend/node_modules
test_api.py
__pycache__/
*.pyc
.DS_Store
*.log
connection_test_result.txt
debug_*.py
test_*.py
temp_*.py
fix_*.py
update_*.py
*.backup
