# =============================================================================
# InsightOCRv2 — Root Environment (Docker Compose)
# =============================================================================
# Used by docker-compose.yml for shared service credentials.
# Backend-specific settings live in backend/.env (see backend/.env.example).
#
# Quick start:
#   ./scripts/setup.sh          # auto-generates secrets + creates .env
# Or manual:
#   cp .env.example .env
#   # replace all CHANGE_ME_* values below
# =============================================================================

# ── Secrets (auto-generated by scripts/setup.sh if still CHANGE_ME_*) ────────
SECRET_KEY=CHANGE_ME_WILL_BE_GENERATED
DB_PASSWORD=CHANGE_ME_WILL_BE_GENERATED
REDIS_PASSWORD=CHANGE_ME_WILL_BE_GENERATED
MINIO_ROOT_PASSWORD=CHANGE_ME_WILL_BE_GENERATED

# ── User-supplied (sensible defaults, edit if needed) ────────────────────────
MINIO_ROOT_USER=insightocr
DB_USER=insightocr_user

# Number of uvicorn workers for backend (1 per CPU core is a good baseline)
WEB_CONCURRENCY=4
