# =============================================================================
# InsightOCR Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and update the values for your environment
# For development: Use .env.development.example as reference
# For production: Use .env.production.example as reference
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL: Backend API base URL
# This variable is exposed to the browser (NEXT_PUBLIC_ prefix)
#
# Development: http://localhost:8000/api/v1
# Production: https://your-backend-domain.com/api/v1 or http://your-ip:8000/api/v1
#
# IMPORTANT: Must include /api/v1 suffix
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
